# Base de données PostgreSQL (obligatoire en prod Vercel)
#
# Option A — Vercel Postgres (Storage) : rien à faire, le build mappe automatiquement
#   POSTGRES_PRISMA_URL → DATABASE_URL
#   POSTGRES_URL_NON_POOLING → DIRECT_URL
#
# Option B — Neon ou autre hébergeur :
# DATABASE_URL = URL pooled (host avec « -pooler » sur Neon)
# DIRECT_URL   = URL directe (sans pooler) — obligatoire pour le build Vercel
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# OpenAI
OPENAI_API_KEY=sk-votre-cle-openai

# Google Maps / Places API
# Créer une clé sur https://console.cloud.google.com/
# Activer "Places API (New)"
GOOGLE_MAPS_API_KEY=votre-cle-google-maps

# Resend (campagnes email)
# https://resend.com/api-keys
# Domaine vérifié Resend — utilisé comme expéditeur (FROM)
RESEND_API_KEY=re_votre-cle
RESEND_FROM="MatoFlow <contact@matoflow.fr>"

# URL publique de l'app déployée (suivi ouverture des campagnes)
# Ex. https://matoflow-prospection.vercel.app ou votre domaine custom
# NEXT_PUBLIC_APP_URL=https://votre-app.vercel.app

# Secret cron Vercel (généré automatiquement si vous activez les crons)
# Plan Hobby : 1 exécution/jour (file d'attente traitée aussi toutes les 30s quand l'app est ouverte)
# Plan Pro : possible de passer le cron à */5 * * * * dans vercel.json
# CRON_SECRET=

# --- Connexion Google (équipe) ---
# Générer le secret : openssl rand -base64 32
# NEXTAUTH_URL=https://votre-app.vercel.app
# NEXTAUTH_SECRET=votre-secret-aleatoire
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# Emails administrateurs autorisés (Google OAuth)
AUTH_ALLOWED_EMAILS=gaspard.rivron2@orange.fr,contact@matoflow.fr
# Mettre false une fois Google OAuth configuré sur Vercel
AUTH_DISABLED=true
NEXT_PUBLIC_AUTH_DISABLED=true
